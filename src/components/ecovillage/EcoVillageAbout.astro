---
import { Image } from "astro:assets";
import roomImage from "../../assets/villas/IMG_1702.jpg";

const highlights = [
  {
    title: "Aguas termales exclusivas",
    description: "Acceso ilimitado a las relajantes aguas termales del prestigioso Hotel Sueño Dorado.",
    iconPath: "M12 2C8 6 8 10 12 14C16 10 16 6 12 2ZM5 14c0 4 3 8 7 8s7-4 7-8c-3 2-5 0-7-2-2 2-4 4-7 2z",
  },
  {
    title: "Confort absoluto",
    description: "Aire acondicionado, TV por cable, parqueo privado y atención al detalle en cada rincón.",
    iconPath: "M3 21h18M5 21V8l7-5 7 5v13M9 21v-6h6v6M9 12h.01M15 12h.01",
  },
  {
    title: "Privacidad total",
    description: "Una sola cabaña en la propiedad: el bosque es solo suyo durante su estancia.",
    iconPath: "M12 11c1.66 0 3-1.34 3-3S13.66 5 12 5s-3 1.34-3 3 1.34 3 3 3zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z",
  },
];

const stats = [
  { number: "01", label: "Cabaña única" },
  { number: "24/7", label: "Aguas termales" },
  { number: "100%", label: "Privacidad" },
];
---

<section class="about-section relative overflow-hidden bg-[#efece2] px-6 py-24 md:px-12 md:py-32 lg:py-36">
  {/* Manchas decorativas */}
  <div class="pointer-events-none absolute -top-20 -left-20 h-[400px] w-[400px] rounded-full bg-[#e8efe5] opacity-60 blur-3xl"></div>
  <div class="pointer-events-none absolute bottom-0 right-0 h-[500px] w-[500px] rounded-full bg-[#f0e4c2] opacity-40 blur-3xl"></div>

  <div class="relative mx-auto max-w-7xl">

    <div class="about-grid">

      {/* COLUMNA IZQUIERDA — Contenido */}
      <div class="about-content">

        <div class="flex items-center gap-3">
          <span class="h-px w-12 bg-[#b8954a]"></span>
          <span class="text-xs font-medium uppercase tracking-[0.32em] text-[#b8954a]" style="font-family: 'Manrope', sans-serif;">
            Por qué Eco Village
          </span>
        </div>

        <h2
          class="mt-6 text-5xl font-light leading-[1.02] text-[#1a1f1a] md:text-6xl lg:text-[4.5rem]"
          style="font-family: 'Fraunces', Georgia, serif;"
        >
          El lujo de la
          <span class="italic text-[#1f4029]">simplicidad.</span>
        </h2>

        <p
          class="mt-6 max-w-xl text-base leading-relaxed text-[#4a5048] md:text-lg"
          style="font-family: 'Manrope', sans-serif; font-weight: 300;"
        >
          Una combinación única de aislamiento total y acceso a servicios de
          clase mundial. Sin distracciones. Solo lo esencial, ejecutado con maestría.
        </p>

        <ul class="mt-12 space-y-7">
          {highlights.map((item) => (
            <li class="highlight group flex gap-5">
              <div class="highlight-icon shrink-0">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={item.iconPath} />
                </svg>
              </div>

              <div class="pt-1">
                <h3
                  class="text-xl font-medium text-[#1a1f1a] md:text-[1.375rem]"
                  style="font-family: 'Fraunces', Georgia, serif;"
                >
                  {item.title}
                </h3>
                <p
                  class="mt-2 max-w-md text-sm leading-relaxed text-[#4a5048] md:text-base"
                  style="font-family: 'Manrope', sans-serif; font-weight: 300;"
                >
                  {item.description}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      {/* COLUMNA DERECHA — Imagen + tarjeta de stats */}
      <div class="about-visual">

        <div class="about-frame" aria-hidden="true"></div>

        <div class="about-image-wrapper">
          <Image
            src={roomImage}
            alt="Habitación de Eco Village con cama king y detalles en madera"
            class="about-image"
            loading="lazy"
          />
        </div>

        {/* Tarjeta flotante de stats — ahora full-width para evitar cortes */}
        <div class="about-stats">
          {stats.map((stat, idx) => (
            <div class={`stat-item ${idx > 0 ? "stat-divider" : ""}`}>
              <div
                class="stat-number"
                style="font-family: 'Fraunces', Georgia, serif;"
              >
                {stat.number}
              </div>
              <div
                class="stat-label"
                style="font-family: 'Manrope', sans-serif;"
              >
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Grid principal — proporción dorada para dar más espacio al visual */
  .about-grid {
    display: grid;
    gap: 4rem;
  }

  @media (min-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr 1.05fr;
      gap: 5rem;
      align-items: center;
    }
  }

  @media (min-width: 1280px) {
    .about-grid {
      gap: 6rem;
    }
  }

  /* Iconos circulares */
  .highlight-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 9999px;
    border: 1px solid #b8954a;
    background: rgba(255, 255, 255, 0.6);
    color: #1f4029;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .highlight-icon svg {
    width: 24px;
    height: 24px;
  }

  .highlight:hover .highlight-icon {
    background: #b8954a;
    color: white;
    transform: scale(1.06);
  }

  /* Columna visual */
  .about-visual {
    position: relative;
    width: 100%;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
    padding-bottom: 4rem; /* espacio para la tarjeta de stats en mobile/tablet */
  }

  @media (min-width: 1024px) {
    .about-visual {
      margin: 0;
      max-width: none;
      padding-bottom: 0;
    }
  }

  /* Marco decorativo dorado */
  .about-frame {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    right: -1.5rem;
    bottom: 2.5rem;
    border: 1px solid #b8954a;
    border-radius: 2px;
    z-index: 0;
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .about-frame {
      top: 2rem;
      left: 2rem;
      right: -2rem;
      bottom: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .about-frame {
      bottom: -2rem;
    }
  }

  /* Imagen */
  .about-image-wrapper {
    position: relative;
    z-index: 1;
    overflow: hidden;
    border-radius: 2px;
    box-shadow: 0 24px 60px rgba(20, 25, 20, 0.18);
  }

  .about-image {
    display: block;
    width: 100%;
    height: 420px;
    object-fit: cover;
    object-position: center;
    transition: transform 1.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (min-width: 768px) {
    .about-image {
      height: 520px;
    }
  }

  @media (min-width: 1024px) {
    .about-image {
      height: 600px;
    }
  }

  .about-image-wrapper:hover .about-image {
    transform: scale(1.04);
  }

  /* Tarjeta de stats */
  .about-stats {
    position: relative;
    z-index: 2;
    margin-top: -2.5rem;
    margin-left: 1rem;
    margin-right: 1rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: white;
    padding: 1.5rem 1rem;
    border-radius: 2px;
    box-shadow: 0 16px 40px rgba(20, 25, 20, 0.12);
  }

  @media (min-width: 640px) {
    .about-stats {
      margin-left: 2rem;
      margin-right: 2rem;
      padding: 1.75rem 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .about-stats {
      position: absolute;
      bottom: -3rem;
      left: -2.5rem;
      right: 2rem;
      margin: 0;
      padding: 2rem;
    }
  }

  @media (min-width: 1280px) {
    .about-stats {
      left: -3rem;
      right: 3rem;
      padding: 2.25rem 2.5rem;
    }
  }

  .stat-item {
    text-align: center;
    padding: 0 0.5rem;
  }

  @media (min-width: 768px) {
    .stat-item {
      padding: 0 1rem;
    }
  }

  .stat-number {
    font-size: 1.75rem;
    font-weight: 300;
    color: #1f4029;
    line-height: 1;
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .stat-number {
      font-size: 2.25rem;
    }
  }

  @media (min-width: 1024px) {
    .stat-number {
      font-size: 2.5rem;
    }
  }

  .stat-label {
    margin-top: 0.5rem;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #6b7268;
    line-height: 1.3;
  }

  @media (min-width: 768px) {
    .stat-label {
      font-size: 11px;
    }
  }

  .stat-divider {
    border-left: 1px solid rgba(184, 149, 74, 0.25);
  }

  @media (prefers-reduced-motion: reduce) {
    .highlight-icon,
    .about-image {
      transition: none !important;
    }
    .highlight:hover .highlight-icon,
    .about-image-wrapper:hover .about-image {
      transform: none;
    }
  }
</style>