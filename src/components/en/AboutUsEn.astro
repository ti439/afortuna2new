---
import Reviews from "./ReviewsEn.astro";
const mostrarMas = false;
---

<!-- About us -->
<section id="nosotros" class="bg-[#7A8E89] text-white py-20 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-4xl font-extrabold mb-3">WE ARE AFORTUNADOS</h2>
    <p class="text-lg sm:text-xl font-semibold mb-8">
      15+ years creating local experiences in La Fortuna and Costa Rica
    </p>

    <div class="relative">
      <!-- Full text hidden initially -->
      <div id="texto-nosotros" class="transition-all duration-500 ease-in-out max-h-[320px] overflow-hidden text-left text-lg space-y-4">
        <p class="font-semibold">
          Local platform with our own homes, curated tours, and personalized support so you travel
          without stress.
        </p>

        <ul class="space-y-2">
          <li class="flex items-center gap-2">
            <span class="inline-block h-2 w-2 rounded-full bg-white"></span>
            Vacation homes carefully designed
          </li>
          <li class="flex items-center gap-2">
            <span class="inline-block h-2 w-2 rounded-full bg-white"></span>
            Exclusive agreements with parks and operators
          </li>
          <li class="flex items-center gap-2">
            <span class="inline-block h-2 w-2 rounded-full bg-white"></span>
            Fast local support before and during your trip
          </li>
        </ul>

        <div class="flex flex-wrap gap-4 text-sm sm:text-base">
          <div class="rounded-full border border-white/50 bg-white/10 px-4 py-1">15+ years of experience</div>
          <div class="rounded-full border border-white/50 bg-white/10 px-4 py-1">Personalized attention</div>
        </div>

        <p>
          At <strong>Afortunados</strong>, we have spent more than 15 years turning dreams into
          unforgettable experiences. We started as a simple Facebook page offering local lodging
          and tours in La Fortuna, and thanks to the commitment and passion of our team, today we
          are an integrated and exclusive platform of tourism services in Costa Rica.
        </p>

        <p>
          We have our own vacation homes, carefully designed to provide comfort, warmth, and a
          genuine connection with nature. We also have exclusive agreements with parks and the best
          tour operators in the country, allowing us to offer not only the best prices, but also
          close support to enjoy each destination fully.
        </p>

        <p>
          Our passion for unique experiences goes beyond borders, organizing exclusive trips for
          our clients to fascinating international destinations such as Turkey, Indonesia, Thailand,
          Greece, Mexico, South America, and beautiful European capitals.
        </p>

        <p>
          What truly sets us apart is our multidisciplinary team, with extensive experience in
          hospitality, gastronomy, sales, tour operations, and personalized attention. We strongly
          believe that responsibility and care in every detail make the difference.
        </p>

        <p>
          At <strong>Afortunados</strong>, we do not sell only tourism services, we share
          experiences filled with family warmth, peace of mind, and trust. Our mission is clear: to
          become the leading platform and reference to discover Costa Rica in an authentic, safe,
          personalized way, full of Costa Rican hospitality.
        </p>

        <p class="italic">
          Welcome to Afortunados, where every trip is a story you will want to tell again and
          again!
        </p>
      </div>

      <!-- Gradient to show more -->
      <div id="fade" class="absolute bottom-0 left-0 w-full h-20 bg-gradient-to-t from-[#7A8E89] to-transparent pointer-events-none"></div>

      <!-- Action button -->
      <div class="mt-6 text-center">
        <button
          id="boton-ver-mas"
          class="bg-white text-[#7A8E89] px-6 py-2 font-semibold rounded hover:bg-gray-100 transition"
          aria-expanded="false"
          aria-controls="texto-nosotros"
          onclick="expandirTexto()"
        >
          Read more
        </button>
      </div>
    </div>

    <div class="mt-6">
      <a
        href="https://wa.me/50684597077"
        onclick="return gtagSendEvent(this.href, this.target)"
        class="inline-block border border-white px-6 py-3 rounded-full text-white font-semibold hover:bg-white hover:text-[#7A8E89] transition"
      >
        Talk to an advisor
      </a>
    </div>
  </div>
</section>

<div class="w-full">
  <Reviews />
</div>

<script is:inline>
  function expandirTexto() {
    const texto = document.getElementById("texto-nosotros");
    const boton = document.getElementById("boton-ver-mas");
    const fade = document.getElementById("fade");

    if (texto.classList.contains("max-h-[320px]")) {
      texto.classList.remove("max-h-[320px]");
      texto.classList.add("max-h-[2000px]");
      fade.classList.add("hidden");
      boton.innerText = "Read less";
      boton.setAttribute("aria-expanded", "true");
    } else {
      texto.classList.add("max-h-[320px]");
      texto.classList.remove("max-h-[2000px]");
      fade.classList.remove("hidden");
      boton.innerText = "Read more";
      boton.setAttribute("aria-expanded", "false");
    }
  }
</script>
