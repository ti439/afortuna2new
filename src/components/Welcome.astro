--- 
import "../styles/global.css"; 
import v2 from '../assets/v2.jpg'; 
---

<section
  class="relative h-[90vh] w-full sm:h-screen bg-cover bg-center flex items-center justify-start px-4 sm:px-8 md:px-12"
  style={`background-image: url(${v2.src});`}
>
<div>


  <!-- Fondo oscuro -->
  <div class="absolute inset-0 bg-black/50 z-0"></div>

  <!-- Contenido -->
  <div class="relative z-10 max-w-3xl text-white space-y-5 sm:space-y-6">

    <h1 class="text-4xl sm:text-5xl md:text-5xl lg:text-6xl xl:text-8xl font-extrabold leading-tight">
      UN AMIGO EN COSTA RICA
    </h1>

    <p class="text-base sm:text-lg md:text-xl lg:text-2xl font-semibold uppercase">
      Reserva fácil por WhatsApp y vive Costa Rica como un local
    </p>

    <p class="text-sm sm:text-base md:text-lg lg:text-1xl text-gray-200 leading-relaxed font-semibold">
      Casas, villas y tours alrededor del Volcán Arenal con atención personalizada, recomendaciones reales y logística sin estrés.
    </p>

    <ul class="text-sm sm:text-base md:text-lg text-gray-200 space-y-2 font-semibold">
      <li class="flex items-center gap-2">
        <span class="inline-block h-2 w-2 rounded-full bg-white"></span>
        Check‑in flexible y soporte inmediato
      </li>
      <li class="flex items-center gap-2">
        <span class="inline-block h-2 w-2 rounded-full bg-white"></span>
        Tours privados y transporte confiable
      </li>
      <li class="flex items-center gap-2">
        <span class="inline-block h-2 w-2 rounded-full bg-white"></span>
        Ideal para familias, parejas y grupos
      </li>
    </ul>

    <div class="flex flex-wrap items-center gap-4">
      <a
        href="https://wa.me/50684597077"
        onclick="return gtagSendEvent(this.href, this.target)"
        class="inline-block px-8 py-4 bg-white text-black text-base md:text-lg rounded-full hover:bg-gray-200 transition"
      >
        Cotizar por WhatsApp
      </a>
      <!-- <a
        href="#villas"
        class="inline-block px-6 py-3 border border-white/70 text-white text-sm md:text-base rounded-full hover:bg-white hover:text-black transition"
      >
        Ver disponibilidad
      </a> -->
    </div>

    <p class="text-xs sm:text-sm text-gray-300">
      +120 huéspedes felices · Respuesta rápida
    </p>
  </div>
</section>
