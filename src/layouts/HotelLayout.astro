---
import Hero from "../components/suenodorado/Hero.astro";
import AboutUs from "../components/suenodorado/AboutUs.astro";
import Habitaciones from "../components/suenodorado/Habitaciones.astro";
import Instalaciones from "../components/suenodorado/Instalaciones.astro";
import Experiecias from "../components/suenodorado/Experiencias.astro";
import Contacto from "../components/suenodorado/Contacto.astro";
import Beneficios from "../components/suenodorado/Beneficios.astro";
import Header from '../components/suenodorado/HeaderSueno.astro';
import OtrosHospedajesBanner from "../components/suenodorado/OtrosHospedajesBanner.astro";
import Footer from '../components/Footer.astro';
import Hreflang from "../components/seo/Hreflang.astro";
import ToursTeaser from "../components/ToursTeaser.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";

import "../styles/global.css";

---

<html lang="es">
  <head>
    <title>Hotel Sueño Dorado</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <Hreflang />

  
    <script is:inline>
      function gtagSendEvent(url, target) {
        var isBlank = target === "_blank";
        var navigate = function () {
          if (!isBlank && typeof url === "string") {
            window.location = url;
          }
        };
        if (typeof gtag === "function") {
          gtag("event", "conversion_event_outbound_click", {
            event_callback: navigate,
            event_timeout: 2000,
          });
          return !isBlank;
        }
        navigate();
        return !isBlank;
      }
    </script>
  </head>

  <body class="bg-white text-gray-900">
    <Header />
    <Hero />
    <AboutUs />
    <Habitaciones />
    <Instalaciones />
    <Experiecias />
    <OtrosHospedajesBanner />
    <ToursTeaser />
    <Beneficios />
    <Contacto />
    <Footer/>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
