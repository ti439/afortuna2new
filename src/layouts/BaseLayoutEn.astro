---
export interface Props {
  title?: string;
}
const { title = "Afortunados - Pura Vida" } = Astro.props;

import "../styles/global.css";
import Hreflang from "../components/seo/Hreflang.astro";
import WhatsAppButton from "../components/en/WhatsAppButtonEn.astro";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Afortunados in La Fortuna, Costa Rica. Tours, stays, and local experiences." />
    <title>{title}</title>
    <Hreflang />
  
    <script is:inline>
      function gtagSendEvent(url, target) {
        var isBlank = target === "_blank";
        var navigate = function () {
          if (!isBlank && typeof url === "string") {
            window.location = url;
          }
        };
        if (typeof gtag === "function") {
          gtag("event", "conversion_event_outbound_click", {
            event_callback: navigate,
            event_timeout: 2000,
          });
          return !isBlank;
        }
        navigate();
        return !isBlank;
      }
    </script>
  </head>
  <body class="bg-white text-gray-800 font-sans antialiased">
    <slot />
    <WhatsAppButton />
  </body>
</html>
