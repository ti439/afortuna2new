---
import Hero from "../components/luisita/en/HeroEn.astro";
import AboutUs from "../components/luisita/en/AboutUsEn.astro";
import Habitaciones from "../components/luisita/en/HabitacionesEn.astro";
import Restaurante from "../components/luisita/en/RestauranteEn.astro";
import Instalaciones from "../components/luisita/en/InstalacionesEn.astro";
import Experiencias from "../components/luisita/en/ExperienciasEn.astro";
import Banner1 from "../components/luisita/en/Banner1En.astro";
import Contacto from "../components/luisita/en/ContactoEn.astro";
import Header from "../components/luisita/en/HeaderluisitaEn.astro";
import Footer from "../components/Footer.astro";
import Hreflang from "../components/seo/Hreflang.astro";
import ToursTeaser from "../components/en/ToursTeaserEN.astro";import WhatsAppButton from "../components/en/WhatsAppButtonEn.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <title>Hotel Catarata Resort</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <Hreflang />
  
    <script is:inline>
      function gtagSendEvent(url, target) {
        var isBlank = target === "_blank";
        var navigate = function () {
          if (!isBlank && typeof url === "string") {
            window.location = url;
          }
        };
        if (typeof gtag === "function") {
          gtag("event", "conversion_event_outbound_click", {
            event_callback: navigate,
            event_timeout: 2000,
          });
          return !isBlank;
        }
        navigate();
        return !isBlank;
      }
    </script>
  </head>

  <body class="bg-white text-gray-900">
    <Header />
    <Hero />
    <AboutUs />
    <Habitaciones />
    <Restaurante />
    <Instalaciones />
    <Banner1 />
    <Contacto />
    <ToursTeaser />
    <Footer />
    <WhatsAppButton />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
